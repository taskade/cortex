            "id": "d6dfe283-bdc9-4e32-9aeb-c4ed8ff05467",
            "text": {
              "ops": [
                {
                  "insert": "RISK"
                },
                {
                  "insert": "\n",
                  "attributes": {
                    "paragraph": true
                  }
                }
              ]
            },
            "format": {

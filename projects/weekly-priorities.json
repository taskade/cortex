            "children": []
          },
          {
            "type": "text",
            "id": "f1300b54-b94f-4a01-bf71-4b40ee80b08f",
            "text": {
              "ops": [
                {
                  "insert": "WHAT WE'RE NOT DOING"
                },
                {
                  "insert": "\n",
                  "attributes": {
                    "paragraph": true
                  }
                }
              ]
            },
            "format": {
              "node": "text",

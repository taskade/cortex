          },
          {
            "type": "text",
            "id": "a0ca383d-7a35-4948-adce-bf70731ddafa",
            "text": {
              "ops": [
                {
                  "insert": "THE TRADEOFF"
                },
                {
                  "insert": "\n",
                  "attributes": {
                    "paragraph": true
                  }
                }
              ]
            },
            "format": {
              "node": "text",

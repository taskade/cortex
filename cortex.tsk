                        },
                        {
                          "type": "text",
                          "id": "805bad84-7fee-4996-803b-10dc5d47e6d8",
                          "text": {
                            "ops": [
                              {
                                "insert": "That keeps effort low while adding a bit of variety and nutritional balance."

                      "collapsed": false,
                      "completed": false,
                      "children": []
                    },
                    {
                      "type": "text",
                      "id": "e5b20b93-5d00-49ea-b0fd-9ae5321312da",
                      "text": {
                        "ops": [
                          {
                            "insert": "Built with Taskade Genesis. Fork this at github.com/taskade/cortex.",
                            "attributes": {
                              "italic": true
                            }
                          },

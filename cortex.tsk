                              "type": "text",
                              "id": "dba1b116-13fc-498b-ac75-76f1b8263be6",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "Q1: Will eating chicken rice again meaningfully hurt my weekly diet pattern?"
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,
                              "completed": false,
                              "children": []
                            },
                            {
                              "type": "text",
                              "id": "5c1d868f-2243-4595-a9fb-732065dfd792",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "Q2: Am I still actively craving it, or does it feel “meh but easy”?"
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"

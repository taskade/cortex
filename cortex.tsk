                              "type": "text",
                              "id": "db2a7337-3896-4d8a-b3f4-fe7d67ca82d3",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "Else → go to step 3."
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }

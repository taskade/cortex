                          "text": {
                            "ops": [
                              {
                                "insert": "Process Yes: repeatable 3-step checklist you can reuse on other days No: full decision log tooling or apps"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }

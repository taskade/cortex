                  "children": [
                    {
                      "type": "text",
                      "id": "66c7ebc5-853a-4608-8354-fee4ad776aaf",
                      "text": {
                        "ops": [
                          {
                            "insert": "Daily Standup",
                            "attributes": {
                              "bold": true
                            }
                          },
                          {
                            "insert": " — Every weekday at 9am, Builder reviews tasks and suggests priorities."

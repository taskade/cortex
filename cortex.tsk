                {
                  "type": "text",
                  "id": "02015213-c6bc-4966-a201-0fabfca1e971",
                  "text": {
                    "ops": [
                      {
                        "insert": "- Pull Stripe dashboard. Capture error code distribution, start timestamp, geographic pattern."
                      },
                      {
                        "insert": "\n",
                        "attributes": {

                              "id": "dbcfffdd-e308-4bac-a732-e975301ca2d4",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "Pick exactly one “default alternative” that is: same price band, same convenience, slightly more variety (e.g., yong tau foo, mixed veg rice, fishball noodles)."
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true

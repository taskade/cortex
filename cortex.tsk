                          "id": "6b148393-a135-416d-a475-53d8a08411e5",
                          "text": {
                            "ops": [
                              {
                                "insert": "Tonight’s decision Yes: choose what you will eat for dinner tonight No: long-term diet planning, weight loss strategy"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }

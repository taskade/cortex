                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "b76d6793-212b-4453-85b9-5adb9f96d55b",
                          "text": {
                            "ops": [
                              {
                                "insert": "Constraints Yes: basic health/variety check, budget, convenience, cravings No: detailed macro tracking, strict medical diets (unless you specify one)"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "text",
                            "children": "text"
                          },

                  },
                  "collapsed": false,
                  "completed": false,
                  "children": [
                    {
                      "type": "text",
                      "id": "1980dc45-cb72-492a-855b-a771ee352a3f",
                      "text": {
                        "ops": [
                          {
                            "insert": "Cortex is a starting point, not a final product. Fork it, rename agents, rewrite playbooks, add your own automations. The structure stays the same — Memory + Intelligence + Reflexes + Interface — but the content becomes yours."
                          },
                          {
                            "insert": "\n",
                            "attributes": {
                              "paragraph": true
                            }
                          }
                        ]
                      },
                      "format": {
                        "node": "text",

                  "children": []
                },
                {
                  "type": "text",
                  "id": "7a65cf06-5eaf-4eb9-b1bb-fef5b1d87f8b",
                  "text": {
                    "ops": [
                      {
                        "insert": "- Classify root cause by T+60. If unresolved at T+60, escalate to SEV-1 and page CTO Mark Chen."
                      },
                      {
                        "insert": "\n",
                        "attributes": {
                          "paragraph": true
                        }
                      }
                    ]
                  },

                              "completed": false,
                              "children": []
                            },
                            {
                              "type": "text",
                              "id": "b33aae3f-64fa-4db5-8afc-963c0c238202",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "Q3: Is there any obvious downside tonight (gut, sleep, budget, guilt ≥ 7/10)?"
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,

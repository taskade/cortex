                  "children": []
                },
                {
                  "type": "text",
                  "id": "62871f39-e41c-4957-9322-d16ace375b09",
                  "text": {
                    "ops": [
                      {
                        "insert": "**Risk A — Rollback clears nothing because the cause is Stripe-side, not ours.**"
                      },
                      {
                        "insert": "\n",
                        "attributes": {
                          "paragraph": true
                        }
                      }
                    ]
                  },
                  "format": {
                    "node": "text",
                    "children": "text"

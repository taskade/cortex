                  "collapsed": false,
                  "completed": false,
                  "children": []
                },
                {
                  "type": "text",
                  "id": "bf0c9fdb-a8f0-42b6-ad83-966211fd543a",
                  "text": {
                    "ops": [
                      {
                        "insert": "The failover path itself may fail and compound the outage. We turn a SEV-2 into a SEV-1 by trying to fix it."
                      },
                      {
                        "insert": "\n",
                        "attributes": {
                          "paragraph": true
                        }
                      }
                    ]
                  },
                  "format": {
                    "node": "text",
                    "children": "text"
                  },
                  "collapsed": false,
                  "completed": false,
                  "children": []
                },
                {
                  "type": "text",
                  "id": "ad0607d1-1e5a-4de0-8545-bfa14d4bae95",
                  "text": {
                    "ops": [
                      {
                        "insert": "Response: before flipping the fallback flag, run one canary transaction through Adyen sandbox. Sandbox passes → flip. Sandbox fails → do NOT flip. Hold at reduced capacity, escalate to SEV-1, and page Mark Chen for a manual vendor call."
                      },
                      {
                        "insert": "\n",
                        "attributes": {
                          "paragraph": true
                        }
                      }
                    ]
                  },
                  "format": {
                    "node": "text",
                    "children": "text"
                  },
                  "collapsed": false,
                  "completed": false,
                  "children": []
                }
              ]
            }

                          "id": "bb8f2de6-00e0-4368-82fc-d671f5aef9cb",
                          "text": {
                            "ops": [
                              {
                                "insert": "Meal options Yes: “chicken rice again” vs “closest easy alternative” (e.g., another hawker rice/noodle dish) No: elaborate home cooking, special-occasion restaurants"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "text",
                            "children": "text"

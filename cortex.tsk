                  "text": {
                    "ops": [
                      {
                        "insert": "- Diff the 06:54 EST deploy (commit 4a82c1f) against 2026-04-12-1830. Three files touched: `charge.ts`, `webhook-handler.ts`, `retry-policy.ts`."
                      },
                      {
                        "insert": "\n",
                        "attributes": {
                          "paragraph": true
                        }
                      }
                    ]
                  },
                  "format": {
                    "node": "text",

                      "type": "text",
                      "id": "f81377f4-d1cb-402d-a213-98a1579e6d93",
                      "text": {
                        "ops": [
                          {
                            "insert": "Context : I’m deciding what to eat for dinner after already having chicken rice for lunch, weighing convenience and satisfaction against variety and minor nutritional concerns."
                          },
                          {
                            "insert": "\n",
                            "attributes": {
                              "paragraph": true
                            }
                          }
                        ]
                      },
                      "format": {
                        "node": "checkbox",
                        "children": null

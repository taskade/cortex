                              "type": "text",
                              "id": "964ef44e-658c-4d85-bbc9-140b0fceae89",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "If answers are “No / Yes / No” → greenlight: buy chicken rice again."
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,
                              "completed": false,
                              "children": []
                            },

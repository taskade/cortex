                              "text": {
                                "ops": [
                                  {
                                    "insert": "Write it down as: “If not chicken rice, I’ll get ______.”"
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }

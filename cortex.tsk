                  "children": []
                },
                {
                  "type": "text",
                  "id": "b87a2dd7-e1c3-42f9-ad8b-710f214e217e",
                  "text": {
                    "ops": [
                      {
                        "insert": "**Risk B — Adyen fallback has not run in production since 2025-12-08.**"
                      },
                      {
                        "insert": "\n",
                        "attributes": {
                          "paragraph": true
                        }
                      }
                    ]
                  },
                  "format": {
                    "node": "text",

                          "id": "0bc56894-0fe7-41a4-a99e-e83ee9d0ddd6",
                          "text": {
                            "ops": [
                              {
                                "insert": "The one killer risk"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "text",
                            "children": "text"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "d1c8bafe-a822-49e0-ac59-2133f3132e02",
                          "text": {
                            "ops": [
                              {
                                "insert": "Killer risk: You turn this into a big “optimize my diet” project, reopen more options, and end up spending 20–30 minutes debating dinner, burning willpower and feeling worse, even if you eat something similar anyway."
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "bullet",
                            "children": "bullet"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "4a18f845-1165-4cf9-8186-35fbbc3549c2",
                          "text": {
                            "ops": [
                              {
                                "insert": "Mitigation: Hard limit yourself to (a) exactly 2 options tonight and (b) a 2-minute timer to decide; anything beyond that is “out of scope” and deferred to a separate, intentional diet-planning session."
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "bullet",
                            "children": "bullet"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []

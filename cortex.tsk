                        {
                          "type": "text",
                          "id": "c58cd34a-312b-40db-b993-dfd5ed4ac7f3",
                          "text": {
                            "ops": [
                              {
                                "insert": "Given only what you shared (already had chicken rice for lunch, now it’s dinner), default to:"

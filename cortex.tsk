                        {
                          "type": "text",
                          "id": "2c91dc7a-b7cc-48ea-9919-611ba8b57d72",
                          "text": {
                            "ops": [
                              {
                                "insert": "A tiny decision protocol that lets you confidently either (a) eat chicken rice again for dinner or (b) switch to a backup option, in under 2 minutes, without overthinking."
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },

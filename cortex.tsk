                  "text": {
                    "ops": [
                      {
                        "insert": "- Remove in-app banner only after error rate holds below 1% for 10 consecutive minutes."
                      },
                      {
                        "insert": "\n",
                        "attributes": {
                          "paragraph": true
                        }
                      }
                    ]
                  },
                  "format": {

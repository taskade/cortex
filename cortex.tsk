                  "collapsed": false,
                  "completed": false,
                  "children": []
                },
                {
                  "type": "text",
                  "id": "8e1054c5-a33d-4c90-bf59-6dcf2fe0ca4f",
                  "text": {
                    "ops": [
                      {
                        "insert": "We cycle through rollback + investigation twice while customers keep hitting errors. Impact extends past T+120."
                      },
                      {
                        "insert": "\n",
                        "attributes": {
                          "paragraph": true
                        }
                      }
                    ]
                  },
                  "format": {
                    "node": "text",
                    "children": "text"
                  },
                  "collapsed": false,
                  "completed": false,
                  "children": []
                },
                {
                  "type": "text",
                  "id": "bcabb1b5-a7aa-4690-b658-0c03b662bf8f",
                  "text": {
                    "ops": [
                      {
                        "insert": "Response: if rollback does not drop error rate within 20 minutes of completion, flip immediately to Adyen fallback regardless of whether investigation has confirmed root cause. Do not wait for certainty."
                      },
                      {
                        "insert": "\n",
                        "attributes": {
                          "paragraph": true
                        }
                      }
                    ]
                  },
                  "format": {
                    "node": "text",
                    "children": "text"
                  },
                  "collapsed": false,
                  "completed": false,
                  "children": []
                },
                {
                  "type": "text",
                  "id": "f7f3bb72-6161-4ab4-9ccf-15f48d0154b0",
                  "text": {
                    "ops": [
                      {
                        "insert": "\n",
                        "attributes": {
                          "paragraph": true
                        }
                      }
                    ]

                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "6408fb57-0e7d-4555-a2d8-049c0e6da7bb",
                          "text": {
                            "ops": [
                              {
                                "insert": "Pick a different but similarly easy hawker-style meal (Option 2) that gives you some vegetables and a different protein."
                              },
                              {

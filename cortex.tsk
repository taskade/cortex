                    },
                    {
                      "type": "text",
                      "id": "3f2363da-d071-4b55-b515-e135938ff9d8",
                      "text": {
                        "ops": [
                          {
                            "insert": "⚔️ Critic: Argue Against This"
                          },
                          {
                            "insert": "\n",
                            "attributes": {
                              "paragraph": true
                            }
                          }
                        ]
                      },
                      "format": {
                        "node": "h2",
                        "children": "text"
                      },
                      "collapsed": false,
                      "completed": false,
                      "children": [
                        {
                          "type": "text",
                          "id": "413e81d7-936a-407e-9fb2-d4ebe8bee936",
                          "text": {
                            "ops": [
                              {
                                "insert": "Decision restated (your move)"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "text",
                            "children": "text"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "98bc397e-89c8-4e53-8a84-0e18dc6a8fd8",
                          "text": {
                            "ops": [
                              {
                                "insert": "You’ve defaulted to: “Since I already had chicken rice for lunch, I should choose a different but similarly easy hawker-style meal for dinner (Option 2), mainly for variety and slightly better nutrition.”"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "text",
                            "children": "text"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "bd9b822f-cc8b-4f79-9c02-78abd50eaf1f",
                          "text": {
                            "ops": [
                              {
                                "insert": "Hidden assumption"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "text",
                            "children": "text"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "e7c19d1d-dabd-40e3-bed1-8873b68c72e6",
                          "text": {
                            "ops": [
                              {
                                "insert": "You’re assuming that marginal gains in variety and nutrition from a single dinner choice outweigh the costs in friction, decision fatigue, and satisfaction tonight."
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "text",
                            "children": "text"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "89898d7a-74bd-4813-9607-1f51ccf439c8",
                          "text": {
                            "ops": [
                              {
                                "insert": "Why that assumption is shaky"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "text",
                            "children": "text"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "fdf343b0-c4e6-4fcf-affd-b42d1b43a77e",
                          "text": {
                            "ops": [
                              {
                                "insert": "You’re overvaluing one-shot “variety” and undervaluing consistency"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "number",
                            "children": "number"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": [
                            {
                              "type": "text",
                              "id": "fdd971f4-0d20-4d70-a250-f0014d23dc6d",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "One meal of “variety” does almost nothing for long‑term nutrition or health. Diet quality is a weekly/monthly property, not a single-meal property."
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,
                              "completed": false,
                              "children": []
                            },
                            {
                              "type": "text",
                              "id": "f4e0c09a-8e34-40f8-aed7-f66add26e75b",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "Many high-performing people deliberately eat the same or similar meals repeatedly because it simplifies life and stabilizes energy. You’re implicitly acting as if repeating chicken rice twice in one day is some big loss, when it’s not, unless your weekly pattern is already terrible."
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,
                              "completed": false,
                              "children": []
                            },
                            {
                              "type": "text",
                              "id": "9c4e219a-1cdb-4b80-8c2e-e63ac28f8336",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "If your usual week already has diverse foods, then tonight’s variety is close to meaningless. Conversely, if your week is mostly chicken rice–type meals, then swapping "
                                  },
                                  {
                                    "insert": "one",
                                    "attributes": {
                                      "italic": true
                                    }
                                  },
                                  {
                                    "insert": " dinner to “noodles or curry” doesn’t actually fix the pattern."
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,
                              "completed": false,
                              "children": []
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "92f073f4-2158-4228-945f-18ac28eddcda",
                          "text": {
                            "ops": [
                              {
                                "insert": "You’re underestimating decision and willpower cost"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "number",
                            "children": "number"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": [
                            {
                              "type": "text",
                              "id": "74f4cc90-37de-4268-8f1f-4dde709d1dcf",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "You frame Option 2 as “slight extra decision effort,” but that’s exactly the trap: you keep a small, nagging decision open, forcing yourself to scan stalls, compare, second-guess. That costs more mental energy than you’re admitting, especially if you’re already tired."
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,
                              "completed": false,
                              "children": []
                            },
                            {
                              "type": "text",
                              "id": "b74e52f5-fc58-45a5-a429-6b1ac9109eff",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "People routinely underestimate how much micro-decisions drain them. The whole point of having a “default meal” is to kill that overhead. You’re deliberately re‑introducing it for a trivial benefit."
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,
                              "completed": false,
                              "children": []
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "24fb2d63-9265-4a34-ad18-42dda551142e",
                          "text": {
                            "ops": [
                              {
                                "insert": "You’re assuming “different hawker meal” is meaningfully more nutritious"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "number",
                            "children": "number"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": [
                            {
                              "type": "text",
                              "id": "7fdcad18-4bba-492c-9eba-bba0f55d0bc9",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "Many alternatives at the same hawker centre are lateral moves: noodles, curry rice, mixed rice loaded with oil, salty sauces, and minimal veg."
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,
                              "completed": false,
                              "children": []
                            },
                            {
                              "type": "text",
                              "id": "0b2cad0b-c7f4-461d-bc09-9719a3b68b5f",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "Without a "
                                  },
                                  {
                                    "insert": "specific",
                                    "attributes": {
                                      "italic": true
                                    }
                                  },
                                  {
                                    "insert": " target (“I’ll get fish soup with extra veg, not fried sides”), “something different” easily becomes “equally bad, just not chicken rice.”"
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,
                              "completed": false,
                              "children": []
                            },
                            {
                              "type": "text",
                              "id": "92ed1606-800a-4799-a4e7-25fce6f7a4f6",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "In other words, you’re paying the friction cost of switching without a guaranteed nutritional upside. You "
                                  },
                                  {
                                    "insert": "hope",
                                    "attributes": {
                                      "italic": true
                                    }
                                  },
                                  {
                                    "insert": " it’s healthier, but your plan doesn’t commit you to that."
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,
                              "completed": false,
                              "children": []
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "454e71bf-8afa-4775-8d67-7be0aa0ae04b",
                          "text": {
                            "ops": [
                              {
                                "insert": "You’re downplaying satisfaction and hedonic payoff"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "number",
                            "children": "number"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": [
                            {
                              "type": "text",
                              "id": "92b2dad0-f5bc-4f5e-92bb-191c87a8ee83",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "You already know you like that specific chicken rice stall; you "
                                  },
                                  {
                                    "insert": "don’t",
                                    "attributes": {
                                      "italic": true
                                    }
                                  },
                                  {
                                    "insert": " know if the alternative will hit the same spot. If dinner misses, you’ll feel vaguely unsatisfied and may compensate later with snacks."
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,
                              "completed": false,
                              "children": []
                            },
                            {
                              "type": "text",
                              "id": "1f885a6a-bd54-4819-a7cd-da7daf9107ed",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "The “wasted chance to eat something different” is a story you’re telling yourself. There will be hundreds of future dinners. Tonight, you might be better off maximizing “hit the spot cheaply and easily” instead of optimizing some abstract rotation rule."
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,
                              "completed": false,
                              "children": []
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "524ff859-cbb4-4875-abad-1501a5bd57fe",
                          "text": {
                            "ops": [
                              {
                                "insert": "You’re mixing micro-health goals with vague long‑term goals"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "number",
                            "children": "number"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": [
                            {
                              "type": "text",
                              "id": "57df19f4-31f0-4b0e-bc51-68336d827c8c",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "You mention weight/health/energy but don’t specify any real constraint (e.g., calorie cap, macro target, doctor’s orders). In that vacuum, you’re using “variety” as a proxy for “healthy,” which is often wrong."
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,
                              "completed": false,
                              "children": []
                            },
                            {
                              "type": "text",
                              "id": "f9dae3f2-b7b8-4c30-95a3-bbf8298c006d",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "If you were serious about health in this decision, the right comparison isn’t “chicken rice vs other hawker food,” it’s “chicken rice vs something clearly lighter/leaner.” Option 2 isn’t that; Option 3 is. You’re half‑moving toward health, but stopping at the most convenient rationalization."
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,
                              "completed": false,
                              "children": []
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "bfc655a4-7a1b-4bb7-8b2e-5423cd5b70f9",
                          "text": {
                            "ops": [
                              {
                                "insert": "Concrete counterexamples"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "text",
                            "children": "text"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "98d0ebd4-8c5c-4bdb-b823-06a240a0a1eb",
                          "text": {
                            "ops": [
                              {
                                "insert": "People who batch-eat: Many folks meal prep the same chicken-and-rice variant for 5–7 days straight and see improved body composition, energy, and reduced decision fatigue. They give up “variety per meal” and still win on health and performance. Your “same dish twice in a day” worry looks trivial in that light."
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "bullet",
                            "children": "bullet"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "7ef6f744-11cb-4afc-b5a6-fa0247c58c6c",
                          "text": {
                            "ops": [
                              {
                                "insert": "Hawker “variety” that backfires: It’s easy to pivot from chicken rice (with at least some cucumber and a relatively lean cut) to, say, laksa or fried kway teow that’s actually heavier in oil, sodium, and calories. You feel virtuous because “it’s different,” but nutritionally you just moved sideways or worse."
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "bullet",
                            "children": "bullet"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "420d545e-ef7a-4f2f-b1c0-a8e0e5479515",
                          "text": {
                            "ops": [
                              {
                                "insert": "The tired-evening trap: On days when people are tired, every extra decision tilts them toward impulsive choices. Forcing yourself to choose something new when low-energy can easily lead to worse outcomes than just repeating the known, acceptable option."
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "bullet",
                            "children": "bullet"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "3986515c-b1a6-4d55-a485-0f2809d4fda0",
                          "text": {
                            "ops": [
                              {
                                "insert": "Putting it bluntly"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "text",
                            "children": "text"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "b2a50c24-7b78-410b-bc99-ec031916b657",
                          "text": {
                            "ops": [
                              {
                                "insert": "Your current “default to Option 2” is a feel-good, pseudo-optimized compromise: it preserves the illusion of being health-conscious and deliberate, but it neither locks in strong nutritional gains nor fully reaps the benefits of low-friction consistency. It’s the worst of both worlds: tiny upside, real cognitive cost."
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "text",
                            "children": "text"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "7c69d50a-9a6b-4ce5-ad65-3baa33ec0876",
                          "text": {
                            "ops": [
                              {
                                "insert": "The one move that would neutralize the strongest objection"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "text",
                            "children": "text"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "f5a48c83-5f67-45b2-b4e0-3e139a063f38",
                          "text": {
                            "ops": [
                              {
                                "insert": "Explicitly decide which axis actually matters "
                              },
                              {
                                "insert": "tonight",
                                "attributes": {
                                  "italic": true
                                }
                              },
                              {
                                "insert": " and commit hard:"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "text",
                            "children": "text"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "6ea16c9e-ae6a-4a18-b77d-f8e36d5186cf",
                          "text": {
                            "ops": [
                              {
                                "insert": "If tonight is about ease and satisfaction: openly choose Option 1 and drop the guilt — “I’m prioritizing low friction and a known good meal; variety can wait.”"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "bullet",
                            "children": "bullet"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "3942a685-ae27-406e-8da2-7a77d0831b4c",
                          "text": {
                            "ops": [
                              {
                                "insert": "If tonight is about real health improvement: upgrade from vague “something different” to a "
                              },
                              {
                                "insert": "specific, lighter choice",
                                "attributes": {
                                  "italic": true
                                }
                              },
                              {
                                "insert": " (e.g., “I’ll get sliced fish soup with extra veg, no fried sides”), i.e., turn Option 3 into a concrete default."
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "bullet",
                            "children": "bullet"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "514eb0e2-2c2e-448b-903f-26686969ba65",
                          "text": {
                            "ops": [
                              {
                                "insert": "Pick one axis and codify a clear default. That kills the decision fatigue objection and makes the choice honestly aligned with your real priority instead of hiding behind “variety.”"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "text",
                            "children": "text"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "760e8b1c-0dba-4675-beab-eae5e134455c",
                      "text": {
                        "ops": [
                          {
                            "insert": "🔬 Researcher: Verify a Claim"
                          },
                          {
                            "insert": "\n",
                            "attributes": {
                              "paragraph": true
                            }
                          }
                        ]
                      },
                      "format": {
                        "node": "h2",
                        "children": "text"
                      },
                      "collapsed": false,
                      "completed": false,
                      "children": [
                        {
                          "type": "text",
                          "id": "6d38d61e-876e-4728-ad6b-e5334988e330",
                          "text": {
                            "ops": [
                              {
                                "insert": "findings"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "text",
                            "children": "text"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "64618244-0fba-4d08-bacd-d7c00a8d7390",
                          "text": {
                            "ops": [
                              {
                                "insert": "Your explicit decision is: “I want to buy chicken rice for dinner,” with the context that you already had chicken rice for lunch."
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "bullet",
                            "children": "bullet"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "5b3e2118-4dd9-4a45-9f77-ac58cfea8372",
                          "text": {
                            "ops": [
                              {
                                "insert": "The long “Researcher Input” you pasted is not a claim about the external world; it is an argument critiquing your "
                              },
                              {
                                "insert": "previous",
                                "attributes": {
                                  "italic": true
                                }
                              },
                              {
                                "insert": " default assumption (“I should pick a different but similar hawker meal for variety and slightly better nutrition”). It functions as reasoning/advice, not as a factual statement that could have an external “primary source.”"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "bullet",
                            "children": "bullet"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "4e1da865-b933-4b9e-9233-bb383d2db101",
                          "text": {
                            "ops": [
                              {
                                "insert": "Because it’s internally generated reasoning (likely your own or a prior AI/coach output), its “primary source” is simply the original text itself. There is no upstream academic paper, guideline, or external author cited or implied for those specific numbered points or the “Putting it bluntly” section."
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "bullet",
                            "children": "bullet"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "cd8a8c36-2d92-4534-a65a-d2b3f3acd417",
                          "text": {
                            "ops": [
                              {
                                "insert": "Some of the "
                              },
                              {
                                "insert": "ideas",
                                "attributes": {
                                  "italic": true
                                }
                              },
                              {
                                "insert": " in that reasoning are consistent with research findings, but they are paraphrased and generalized, not quoted from a specific paper. Examples:"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "bullet",
                            "children": "bullet"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": [
                            {
                              "type": "text",
                              "id": "1d531fa5-4a83-4a5c-b4d9-c583e91fd5c0",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "“Diet quality is a weekly/monthly property, not a single-meal property” aligns with how diet quality indices (e.g., Healthy Eating Index) and guidelines evaluate patterns over time rather than single meals, but the exact phrasing is not from any standard guideline."
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,
                              "completed": false,
                              "children": []
                            },
                            {
                              "type": "text",
                              "id": "a1b349fc-0692-40b9-b861-5102e141a864",
                              "text": {
                                "ops": [
                                  {
                                    "insert": "“People underestimate decision and willpower cost; defaults reduce overhead” echoes findings from decision fatigue and choice architecture research (e.g., work by Roy Baumeister on ego depletion and by Thaler & Sunstein on defaults), but again the text is an interpretation, not a direct citation."
                                  },
                                  {
                                    "insert": "\n",
                                    "attributes": {
                                      "paragraph": true
                                    }
                                  }
                                ]
                              },
                              "format": {
                                "node": "bullet",
                                "children": "bullet"
                              },
                              "collapsed": false,
                              "completed": false,
                              "children": []
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "e72f4ce5-1b8a-419d-b1c8-32ebe70cc1f5",
                          "text": {
                            "ops": [
                              {
                                "insert": "Therefore, there is no verifiable external “primary source” for the full argument as written; it appears to be a synthesized advisory piece rather than a claim traceable to a single study or policy document."
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "bullet",
                            "children": "bullet"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "0c3a5224-9c46-4add-9b70-b0907ed79ace",
                          "text": {
                            "ops": [
                              {
                                "insert": "sources"
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]
                          },
                          "format": {
                            "node": "text",
                            "children": "text"
                          },
                          "collapsed": false,
                          "completed": false,
                          "children": []
                        },
                        {
                          "type": "text",
                          "id": "0321d490-363c-46cf-a27b-07d5f2155c96",
                          "text": {
                            "ops": [
                              {
                                "insert": "U.S. Department of Health and Human Services and U.S. Department of Agriculture. Dietary Guidelines for Americans, 2020–2025. Emphasizes overall dietary patterns over time rather than single meals. "
                              },
                              {
                                "insert": "https://www.dietaryguidelines.gov",
                                "attributes": {
                                  "link": "https://www.dietaryguidelines.gov"
                                }
                              },
                              {
                                "insert": "\n",
                                "attributes": {
                                  "paragraph": true
                                }
                              }
                            ]

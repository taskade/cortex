                  "children": []
                },
                {
                  "type": "text",
                  "id": "c31580e9-b2dd-4391-a6eb-55fe0c2a165c",
                  "text": {
                    "ops": [
                      {
                        "insert": "- Ping Stripe support directly. Ask: any known degradation on card auth endpoints in US-East-1?"
                      },
                      {
                        "insert": "\n",
                        "attributes": {
                          "paragraph": true
                        }
                      }
                    ]
